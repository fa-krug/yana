    "Reader View Inspired by NetNewsWire": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leseansicht inspiriert von NetNewsWire"
          }
        }
      }
    },
    "Yana is free and open source. The list of built-in sources grows from what people ask for, so suggest one on the issue board. Thanks to the NetNewsWire team, whose clean reader view shaped how articles look here.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Yana ist kostenlos und quelloffen. Die Liste der integrierten Quellen wächst mit den Wünschen der Nutzer, also schlage eine im Issue-Board vor. Dank an das NetNewsWire-Team, dessen aufgeräumte Leseansicht die Darstellung der Artikel hier geprägt hat."
          }
        }
      }
    },
    "Active Provider": {
      "comment": "A label for the currently selected AI provider.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "de": {
