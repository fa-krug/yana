    "Welcome to Yana": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Willkommen bei Yana"
          }
        }
      }
    },
    "Your own private feed reader — all your sources, gathered on your device.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein eigener privater Feed-Reader – alle deine Quellen, gesammelt auf deinem Gerät."
          }
        }
      }
    },
    "Everything in One Timeline": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alles in einer Timeline"
          }
        }
      }
    },
    "RSS, YouTube, Reddit, podcasts, and whole websites flow into a single endless timeline you swipe through.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "RSS, YouTube, Reddit, Podcasts und ganze Websites fließen in eine einzige endlose Timeline, durch die du wischst."
          }
        }
      }
    },
    "Organize with Tags": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Mit Tags organisieren"
          }
        }
      }
    },
    "Tag your feeds to filter the timeline, and star articles to keep them around.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versieh deine Feeds mit Tags, um die Timeline zu filtern, und markiere Artikel mit einem Stern, um sie zu behalten."
          }
        }
      }
    },
    "Private by Design": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Privat von Grund auf"
          }
        }
      }
    },
    "Everything is fetched and stored on your device. No account, no server, no tracking.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Alles wird auf deinem Gerät geladen und gespeichert. Kein Konto, kein Server, kein Tracking."
          }
        }
      }
    },
    "Optional AI": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Optionale KI"
          }
        }
      }
    },
